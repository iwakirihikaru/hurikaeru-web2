    "push:force": "clasp push --force",
    "push:force:codeonly": "clasp push --force",
    "pull": "clasp pull",
    "open": "clasp open",
    "web:dev": "powershell -ExecutionPolicy Bypass -Command \"Set-Location -LiteralPath './webapp'; & 'C:/Program Files/nodejs/npm.cmd' run dev\"",
