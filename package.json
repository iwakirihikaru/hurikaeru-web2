    "sync:admin-shell": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-admin-shell-config.ps1",
    "export:admin-shell-static": "powershell -ExecutionPolicy Bypass -File ./scripts/export-admin-shell-static.ps1",
    "set:admin-primary-shell": "powershell -ExecutionPolicy Bypass -File ./scripts/set-admin-primary-shell-urls.ps1",
    "deploy:admin": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-admin-webapp.ps1",
