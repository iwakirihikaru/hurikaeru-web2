    "portable:serve": "node ./scripts/serve-portable.js",
    "refresh:portable-tenant": "powershell -ExecutionPolicy Bypass -File ./scripts/refresh-portable-tenant.ps1",
    "build:update-bundle": "node ./scripts/build-update-bundle.js",
