    "deploy:all": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-all.ps1",
    "deploy:tenants": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-all.ps1",
    "deploy:full": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-full.ps1",
    "setup:tenant": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap-tenant.ps1",
    "check:tenant": "powershell -ExecutionPolicy Bypass -File ./scripts/check-tenant.ps1",
    "refresh:tenant-shell": "powershell -ExecutionPolicy Bypass -File ./scripts/refresh-tenant-shell-cache.ps1",
    "list:tenants": "powershell -ExecutionPolicy Bypass -File ./scripts/list-tenants.ps1",
